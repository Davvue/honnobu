{
  "name": "honnobu",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source and self-hosted book tracker",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web start",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module"
}
